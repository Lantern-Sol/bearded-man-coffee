{%- doc -%}
  Two-tier progress bar shown at the top of the cart drawer.
  Tier 1: Free shipping  — reads `settings.cart_free_shipping_threshold`.
  Tier 2: Free gift       — reads `settings.cart_free_gift_threshold` + `settings.cart_free_gift_product`.
{%- enddoc -%}

{% liquid
  # ── Tier 1: free shipping ──
  assign shipping_threshold_input = settings.cart_free_shipping_threshold | default: '50'
  assign shipping_threshold_cents = shipping_threshold_input | times: 100.0 | round
  if shipping_threshold_cents <= 0
    assign shipping_threshold_cents = 5000
  endif

  # ── Tier 2: free gift ──
  assign gift_enabled = settings.cart_free_gift_enabled
  assign gift_threshold_input = settings.cart_free_gift_threshold | default: '100'
  assign gift_threshold_cents = gift_threshold_input | times: 100.0 | round
  if gift_threshold_cents <= 0
    assign gift_threshold_cents = 10000
  endif

  # ── Gift product handle ──
  # Theme-level product settings return a handle (string), not a product object.
  # We pass the handle to JS which resolves the variant via /products/{handle}.js
  # because all_products[] has a 20-handle-per-page limit that causes silent failures.
  assign gift_product_handle = settings.cart_free_gift_product

  # ── Check if gift is already in cart ──
  assign gift_in_cart = false
  assign cart_total_excluding_gift = 0
  for item in cart.items
    if item.properties['_gift'] == 'true'
      assign gift_in_cart = true
    else
      assign cart_total_excluding_gift = cart_total_excluding_gift | plus: item.original_line_price
    endif
  endfor

  # ── Current cart value ──
  # Use total excluding gift items so the $0 gift doesn't affect threshold calculation.
  assign current = cart_total_excluding_gift

  # ── Shipping tier calculations ──
  assign shipping_remaining = shipping_threshold_cents | minus: current
  if shipping_remaining < 0
    assign shipping_remaining = 0
  endif
  assign shipping_met = false
  if cart.item_count > 0 and shipping_remaining == 0
    assign shipping_met = true
  endif

  # ── Gift tier calculations ──
  assign gift_remaining = gift_threshold_cents | minus: current
  if gift_remaining < 0
    assign gift_remaining = 0
  endif
  assign gift_met = false
  if cart.item_count > 0 and gift_remaining == 0
    assign gift_met = true
  endif

  # ── Progress bar ──
  # The bar spans from $0 to the higher of the two thresholds.
  if gift_enabled
    assign bar_max = gift_threshold_cents
  else
    assign bar_max = shipping_threshold_cents
  endif

  assign progress_percent = current | times: 1.0 | divided_by: bar_max | times: 100 | round
  if progress_percent > 100
    assign progress_percent = 100
  endif
  if progress_percent < 0
    assign progress_percent = 0
  endif

  # Position of the shipping marker on the bar (as a %).
  if gift_enabled
    assign shipping_marker_pct = shipping_threshold_cents | times: 1.0 | divided_by: bar_max | times: 100 | round
  else
    assign shipping_marker_pct = 100
  endif
%}

<div
  class="cart-shipping-progress"
  data-gift-enabled="{{ gift_enabled }}"
  data-gift-threshold-cents="{{ gift_threshold_cents }}"
  data-gift-in-cart="{{ gift_in_cart }}"
  data-gift-met="{{ gift_met }}"
>
  {%- comment -%} ── Text messages ── {%- endcomment -%}
  <p class="cart-shipping-progress__text">
    {%- if gift_enabled and gift_met -%}
      <span>You&rsquo;ve unlocked </span><strong>free shipping</strong><span> + a </span><strong>free gift! 🎁</strong>
    {%- elsif shipping_met and gift_enabled -%}
      <span>Free shipping unlocked! Add </span><strong>{{ gift_remaining | money }}</strong><span> more for a </span><strong>free gift! 🎁</strong>
    {%- elsif shipping_met -%}
      <span>You&rsquo;ve unlocked </span><strong>free shipping!</strong>
    {%- else -%}
      <span>Add </span><strong>{{ shipping_remaining | money }}</strong><span> to your order to </span><strong>unlock free shipping!</strong>
    {%- endif -%}
  </p>

  {%- comment -%} ── Progress bar ── {%- endcomment -%}
  <div
    class="cart-shipping-progress__bar"
    role="progressbar"
    aria-valuemin="0"
    aria-valuemax="100"
    aria-valuenow="{{ progress_percent }}"
    style="--progress: {{ progress_percent }}%;"
  >
    <span class="cart-shipping-progress__track"></span>
    <span class="cart-shipping-progress__fill"></span>

    {%- comment -%} Truck icon — fixed at shipping milestone {%- endcomment -%}
    <span
      class="cart-shipping-progress__icon cart-shipping-progress__icon--truck{% if shipping_met %} cart-shipping-progress__icon--reached{% endif %}"
      style="left: {{ shipping_marker_pct }}%;"
      aria-hidden="true"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="10" viewBox="0 0 14 10" fill="none">
        <path d="M1 1.5h7v5.25H1zM8 3h2.5l2 2v1.75H8z" stroke="currentColor" stroke-width="0.8" stroke-linejoin="round"/>
        <circle cx="3.25" cy="7.75" r="1" fill="currentColor"/>
        <circle cx="10.25" cy="7.75" r="1" fill="currentColor"/>
      </svg>
    </span>

    {%- comment -%} Gift icon — fixed at 100% {%- endcomment -%}
    <span class="cart-shipping-progress__icon cart-shipping-progress__icon--gift{% if gift_met %} cart-shipping-progress__icon--reached{% endif %}" aria-hidden="true">
      <svg xmlns="http://www.w3.org/2000/svg" width="13" height="10" viewBox="0 0 13 10" fill="none">
        <path d="M1 4h11v5.5H1zM6.5 4v5.5M1 2h11v2H1zM6.5 2c-1-1.4 0-2 .8-1.4.6.5.4 1.4-.8 1.4Zm0 0c1-1.4 0-2-.8-1.4-.6.5-.4 1.4.8 1.4Z" stroke="currentColor" stroke-width="0.8" stroke-linejoin="round"/>
      </svg>
    </span>
  </div>
</div>

{%- comment -%} ── Auto-add / remove gift product line item ── {%- endcomment -%}
{%- if gift_enabled and gift_product_handle != blank -%}
<script>
  (function() {
    if (window.__giftTierInit) return;
    window.__giftTierInit = true;

    var _gv = null; // resolved async via Product AJAX API
    var _handle = {{ gift_product_handle | json }};
    var isUpdating = false;
    var SAFETY_TIMEOUT = 10000;
    var debounceTimer = null;

    // Dispatch cart:update WITHOUT section HTML so cart-items-component
    // falls back to its own sectionRenderer.renderSection() re-fetch.
    // This is more reliable than bundling sections in the Cart API response
    // because the theme's own re-fetch + morph pipeline handles all edge cases.
    function notifyCartChanged() {
      var evt = new CustomEvent('cart:update', {
        bubbles: true,
        detail: {
          resource: null,
          sourceId: 'gift-tier-sync',
          data: { source: 'gift-tier-sync' }
        }
      });
      document.dispatchEvent(evt);
    }

    // Make a cart API call, then notify all cart components to re-render
    function cartApiCall(url, payload) {
      return fetch(url, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
        body: JSON.stringify(payload)
      })
      .then(function(res) { return res.json(); })
      .then(function(data) {
        notifyCartChanged();
        return data;
      });
    }

    function sync() {
      if (isUpdating) return;

      var el = document.querySelector('.cart-shipping-progress[data-gift-enabled="true"]');
      if (!el || !_gv) return;

      isUpdating = true;
      var safetyTimer = setTimeout(function() { isUpdating = false; }, SAFETY_TIMEOUT);

      fetch('/cart.js', { headers: { 'Accept': 'application/json' } })
      .then(function(res) { return res.json(); })
      .then(function(cart) {
        var thresholdCents = parseInt(el.dataset.giftThresholdCents, 10);
        var giftItems = [];       // items with _gift property
        var rogueGiftItems = [];  // gift product added WITHOUT _gift property (manual/console abuse)
        var totalExcludingGift = 0;

        cart.items.forEach(function(item) {
          if (item.properties && item.properties._gift === 'true') {
            giftItems.push(item);
          } else if (item.variant_id === _gv) {
            // Someone added the gift product directly (no _gift flag) — treat as rogue
            rogueGiftItems.push(item);
          } else {
            totalExcludingGift += item.original_line_price;
          }
        });

        // Guard: batch-remove rogue gift items (added via console, direct URL, etc.)
        if (rogueGiftItems.length > 0) {
          var updates = {};
          rogueGiftItems.forEach(function(item) { updates[item.key] = 0; });
          return cartApiCall('/cart/update.js', { updates: updates });
        }

        var thresholdMet = cart.items.length > giftItems.length && totalExcludingGift >= thresholdCents;

        // Batch-remove duplicate gifts — keep first only
        if (giftItems.length > 1) {
          var updates = {};
          giftItems.slice(1).forEach(function(item) { updates[item.key] = 0; });
          return cartApiCall('/cart/update.js', { updates: updates });
        }

        // Cap gift quantity to 1
        if (giftItems.length === 1 && giftItems[0].quantity > 1) {
          return cartApiCall('/cart/change.js', { id: giftItems[0].key, quantity: 1 });
        }

        // Add gift when threshold met
        if (thresholdMet && giftItems.length === 0) {
          return cartApiCall('/cart/add.js', {
            items: [{ id: _gv, quantity: 1, properties: { _gift: 'true' } }]
          });
        }

        // Remove gift when threshold not met
        if (!thresholdMet && giftItems.length > 0) {
          return cartApiCall('/cart/change.js', { id: giftItems[0].key, quantity: 0 });
        }
      })
      .catch(function() {})
      .finally(function() {
        clearTimeout(safetyTimer);
        isUpdating = false;
      });
    }

    function debouncedSync() {
      clearTimeout(debounceTimer);
      debounceTimer = setTimeout(sync, 600);
    }

    // Resolve the gift variant ID via Product AJAX API, then run initial sync.
    // This avoids the all_products[] 20-handle-per-page Liquid limit.
    fetch('/products/' + _handle + '.js', { headers: { 'Accept': 'application/json' } })
      .then(function(res) { return res.ok ? res.json() : Promise.reject(res.status); })
      .then(function(product) {
        var v = product.variants.find(function(v) { return v.available; }) || product.variants[0];
        if (v) _gv = v.id;
        sync();
      })
      .catch(function() {});

    // Re-run whenever the cart drawer re-renders
    var observer = new MutationObserver(function() { debouncedSync(); });
    var target = document.querySelector('cart-items-component') || document.body;
    observer.observe(target, { subtree: true, childList: true });

    // Re-sync after cart changes from other components.
    // Use independent setTimeout (not debouncedSync) so MutationObserver
    // debounce resets during DOM morphing can't cancel these triggers.
    document.addEventListener('cart:update', function() {
      setTimeout(sync, 500);
    });
    document.addEventListener('cart:add', function() {
      setTimeout(sync, 500);
    });
  })();
</script>
{%- endif -%}

{% stylesheet %}
  .cart-shipping-progress {
    --progress-track-color: #f2edd7;
    --progress-fill-color: #c7893a;
    --progress-icon-bg: #f2edd7;
    --progress-icon-color: #3d3a35;
    --progress-icon-reached-bg: #c7893a;
    --progress-icon-reached-color: #fff;

    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    width: 100%;
    padding: 0 15px;
  }

  .cart-shipping-progress__text {
    font-family: 'Inter', sans-serif;
    font-size: 13px;
    line-height: 1.4;
    color: #1b1b1b;
    text-align: center;
    margin: 0;
  }

  .cart-shipping-progress__text strong {
    font-weight: 700;
  }

  .cart-shipping-progress__bar {
    position: relative;
    width: 100%;
    height: 6px;
  }

  .cart-shipping-progress__track {
    position: absolute;
    inset: 0;
    background-color: var(--progress-track-color);
    border-radius: 0 12px 12px 0;
    display: block;
  }

  .cart-shipping-progress__fill {
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: var(--progress, 0%);
    background-color: var(--progress-fill-color);
    transition: width 0.4s ease;
    display: block;
  }

  .cart-shipping-progress__icon {
    position: absolute;
    top: 50%;
    width: 22px;
    height: 22px;
    background-color: var(--progress-icon-bg);
    border: 1px solid var(--progress-icon-bg);
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--progress-icon-color);
    transform: translate(-50%, -50%);
    pointer-events: none;
    transition: background-color 0.3s ease, color 0.3s ease;
  }

  .cart-shipping-progress__icon--reached {
    background-color: var(--progress-icon-reached-bg);
    border-color: var(--progress-icon-reached-bg);
    color: var(--progress-icon-reached-color);
  }

  .cart-shipping-progress__icon--truck {
    z-index: 1;
  }

  .cart-shipping-progress__icon--gift {
    left: 100%;
  }

  .cart-shipping-progress__icon svg {
    display: block;
  }
{% endstylesheet %}
