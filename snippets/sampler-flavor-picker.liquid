{%- doc -%}
  Renders 6 flavor dropdown selectors for the Sampler Six product.
  Each dropdown becomes a line item property (Flavor 1 … Flavor 6).

  Must be rendered inside a product template. Reads from the "coffee"
  collection to build the option list dynamically.

  @param {object} product - The current product
  @param {object} section - The section object
{%- enddoc -%}

{%- liquid
  assign coffee_collection = collections['coffee']
  assign coffee_products = coffee_collection.products
-%}

<script type="application/json" data-sampler-coffees>
  [
    {%- assign sampler_first = true -%}
    {%- for coffee in coffee_products -%}
      {%- unless coffee.handle == 'sampler-six' -%}
        {%- unless sampler_first -%},{%- endunless -%}
        {%- liquid
          assign sampler_image = coffee.featured_image
          for variant in coffee.variants
            if variant.option1 == '2.5 oz' and variant.image != blank
              assign sampler_image = variant.image
              break
            endif
          endfor
        -%}
        {
          "title": {{ coffee.title | json }},
          "image": {{ sampler_image | image_url: width: 80, height: 80, crop: 'center' | json }},
          "description": {{ coffee.description | strip_html | truncate: 100 | json }},
          "available": {{ coffee.available }}
        }
        {%- assign sampler_first = false -%}
      {%- endunless -%}
    {%- endfor -%}
  ]
</script>

<sampler-flavor-picker class="sampler-picker" data-count="6">
  <fieldset class="sampler-picker__fieldset">
    <legend class="sampler-picker__legend">Pick Your 6 Coffees</legend>
    <p class="sampler-picker__subtitle">Choose a flavor for each of the 6 sample bags in your Sampler Six.</p>

    <div class="sampler-picker__grid">
      {%- for i in (1..6) -%}
        <div class="sampler-picker__slot" data-slot="{{ i }}">
          <label class="sampler-picker__label" id="sampler-label-{{ i }}-{{ section.id }}">
            Flavor {{ i }}
          </label>
          <div class="sampler-picker__dropdown" data-flavor-index="{{ i }}">
            <button type="button" class="sampler-picker__trigger"
              role="combobox" aria-expanded="false"
              aria-haspopup="listbox"
              aria-controls="sampler-listbox-{{ i }}-{{ section.id }}"
              aria-labelledby="sampler-label-{{ i }}-{{ section.id }}">
              <span class="sampler-picker__trigger-text">Select a coffee…</span>
              <svg class="sampler-picker__caret" aria-hidden="true" focusable="false" viewBox="0 0 10 6">
                {%- render 'icon', icon: 'caret' -%}
              </svg>
            </button>
            <ul role="listbox" id="sampler-listbox-{{ i }}-{{ section.id }}"
              class="sampler-picker__listbox" hidden>
            </ul>
          </div>
        </div>
      {%- endfor -%}
    </div>

    <p class="sampler-picker__error" hidden>Please select a coffee for every slot before adding to cart.</p>
  </fieldset>
</sampler-flavor-picker>

<script src="{{ 'sampler-flavor-picker.js' | asset_url }}" type="module"></script>

{% stylesheet %}
  .sampler-picker {
    display: block;
    width: 100%;
  }

  .sampler-picker__fieldset {
    border: 0;
    padding: 0;
    margin: 0;
  }

  .sampler-picker__legend {
    font-family: var(--font-primary--family);
    font-weight: 600;
    font-size: 1rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    margin-bottom: 0.25rem;
  }

  .sampler-picker__subtitle {
    font-size: var(--font-size--sm);
    color: var(--color-foreground-secondary, rgb(var(--color-foreground-rgb) / 0.7));
    margin: 0 0 1rem;
  }

  .sampler-picker__grid {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .sampler-picker__slot {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .sampler-picker__label {
    display: block;
    font-size: var(--font-size--sm);
    font-weight: 500;
    white-space: nowrap;
    min-width: 4.5rem;
    color: var(--color-foreground);
  }

  /* --- Custom dropdown --- */
  .sampler-picker__dropdown {
    position: relative;
    flex: 1;
  }

  .sampler-picker__trigger {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    width: 100%;
    border: 1px solid rgb(var(--color-foreground-rgb) / 0.25);
    border-radius: var(--style-border-radius-inputs, 4px);
    background: transparent;
    padding: var(--padding-md, 0.625rem) var(--padding-lg, 0.875rem);
    padding-right: calc(var(--padding-lg, 0.875rem) + 1.25rem);
    font-family: var(--font-body--family);
    font-size: var(--font-size--sm);
    color: var(--color-foreground);
    cursor: pointer;
    text-align: left;
    transition: border-color 0.2s ease;
  }

  .sampler-picker__trigger:hover {
    border-color: var(--color-variant-hover-border, var(--color-foreground));
  }

  .sampler-picker__trigger:focus-visible {
    outline: var(--focus-outline-width, 2px) solid currentcolor;
    outline-offset: var(--focus-outline-offset, 2px);
  }

  .sampler-picker__trigger-thumb {
    width: 24px;
    height: 24px;
    border-radius: 3px;
    object-fit: cover;
    flex-shrink: 0;
  }

  .sampler-picker__trigger-text {
    flex: 1;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .sampler-picker__caret {
    position: absolute;
    right: var(--padding-md, 0.625rem);
    top: 50%;
    transform: translateY(-50%);
    width: var(--icon-size-2xs, 0.625rem);
    height: var(--icon-size-2xs, 0.625rem);
    pointer-events: none;
    transition: transform 0.2s ease;
  }

  .sampler-picker__trigger[aria-expanded="true"] .sampler-picker__caret {
    transform: translateY(-50%) rotate(180deg);
  }

  .sampler-picker__dropdown[data-filled] .sampler-picker__trigger {
    border-color: var(--color-foreground);
  }

  /* --- Listbox --- */
  .sampler-picker__listbox {
    position: absolute;
    top: calc(100% + 4px);
    left: 0;
    right: 0;
    margin: 0;
    padding: 0.25rem 0;
    list-style: none;
    background: var(--color-background);
    border: 1px solid rgb(var(--color-foreground-rgb) / 0.2);
    border-radius: var(--style-border-radius-inputs, 4px);
    box-shadow: 0 4px 16px rgb(0 0 0 / 0.12);
    max-height: 280px;
    overflow-y: auto;
    z-index: var(--layer-overlay, 16);
  }

  /* --- Option --- */
  .sampler-picker__option {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    padding: 0.5rem 0.75rem;
    cursor: pointer;
    transition: background-color 0.15s ease;
  }

  .sampler-picker__option:hover,
  .sampler-picker__option[data-focused="true"] {
    background: rgb(var(--color-foreground-rgb) / 0.06);
  }

  .sampler-picker__option[aria-selected="true"] {
    background: rgb(var(--color-foreground-rgb) / 0.08);
  }

  .sampler-picker__option[aria-disabled="true"] {
    opacity: 0.45;
    cursor: not-allowed;
  }

  .sampler-picker__option-img {
    width: 40px;
    height: 40px;
    border-radius: 4px;
    object-fit: cover;
    flex-shrink: 0;
  }

  .sampler-picker__option-text {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
    min-width: 0;
  }

  .sampler-picker__option-title {
    font-size: var(--font-size--sm);
    font-weight: 500;
    color: var(--color-foreground);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .sampler-picker__option-desc {
    font-size: 0.75rem;
    color: var(--color-foreground-secondary, rgb(var(--color-foreground-rgb) / 0.6));
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .sampler-picker__error {
    color: rgb(var(--color-error-rgb, 204 0 0) / 1);
    font-size: var(--font-size--sm);
    margin-top: 0.75rem;
  }

  .sampler-picker__error:not([hidden]) {
    animation: sampler-shake 0.3s ease;
  }

  @keyframes sampler-shake {
    0%, 100% { transform: translateX(0); }
    25% { transform: translateX(-4px); }
    75% { transform: translateX(4px); }
  }

  @media screen and (max-width: 749px) {
    .sampler-picker__grid {
      margin-bottom: 1rem;
    }

    .sampler-picker__listbox {
      max-height: 220px;
    }
  }
{% endstylesheet %}
