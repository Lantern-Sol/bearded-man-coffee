{% # theme-check-disable %}
{%- unless settings.type_body_font.system? -%}
  <link
    rel="preload"
    as="font"
    href="{{ settings.type_body_font | font_url }}"
    type="font/woff2"
    crossorigin
    fetchpriority="low"
  >
{%- endunless -%}
{%- unless settings.type_subheading_font.system? -%}
  <link
    rel="preload"
    as="font"
    href="{{ settings.type_subheading_font | font_url }}"
    type="font/woff2"
    crossorigin
    fetchpriority="low"
  >
{%- endunless -%}
{%- if settings.use_shopify_heading_accent_fonts -%}
  {%- unless settings.type_heading_font.system? -%}
    <link
      rel="preload"
      as="font"
      href="{{ settings.type_heading_font | font_url }}"
      type="font/woff2"
      crossorigin
      fetchpriority="low"
    >
  {%- endunless -%}
  {%- unless settings.type_accent_font.system? -%}
    <link
      rel="preload"
      as="font"
      href="{{ settings.type_accent_font | font_url }}"
      type="font/woff2"
      crossorigin
      fetchpriority="low"
    >
  {%- endunless -%}
{%- else -%}
  <link
    rel="preload"
    as="font"
    href="{{ 'FoundersGrotesk-Semibold.woff2' | asset_url }}"
    type="font/woff2"
    crossorigin
    fetchpriority="low"
  >
  <link
    rel="preload"
    as="font"
    href="{{ 'FoundersGrotesk-Semibold.woff' | asset_url }}"
    type="font/woff"
    crossorigin
    fetchpriority="low"
  >
  <link
    rel="preload"
    as="font"
    href="{{ 'FoundersGrotesk-Regular.woff2' | asset_url }}"
    type="font/woff2"
    crossorigin
    fetchpriority="low"
  >
  <link
    rel="preload"
    as="font"
    href="{{ 'FoundersGrotesk-Regular.woff' | asset_url }}"
    type="font/woff"
    crossorigin
    fetchpriority="low"
  >
{%- endif -%}
{% # theme-check-enable %}
