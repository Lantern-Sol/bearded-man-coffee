{%- doc -%}
  This snippet is used to render a product card.
  It is used in the product block, featured product block, and the product card block.
  The product object is null or when placeholders are rendered.

  @param {object} product - The product object
  @param {object} children - The children of the product card
  @param {object} [block] - The block object
  @param {number} [product_card_gap] - The gap between the product card children (overrides block settings)
  @param {string} [layout] - vertical (default) or horizontal
  @param {number} [horizontal_image_width] - Image column width in px when layout is horizontal
{%- enddoc -%}

{% assign block_settings = block.settings %}
{% assign card_layout = layout | default: 'vertical' %}
{% assign card_horizontal_image_width = horizontal_image_width | default: 96 %}

{% style %}
  {% if request.visual_preview_mode %}
    product-card[data-product-transition] {
      width: 100%;
      min-width: 250px;
    }
  {% endif %}
{% endstyle %}

{% liquid
  assign has_quick_add = false
  if settings.quick_add and product.available
    assign has_quick_add = true
  endif

  assign has_mobile_quick_add = false
  if has_quick_add and settings.mobile_quick_add
    assign has_mobile_quick_add = true
  endif

  assign product_card_id = 'product-card-link-' | append: block.id | append: '-' | append: product.id
  assign product_card_gap_value = product_card_gap | default: block_settings.product_card_gap

  # Logic to determine which variant URL to use (matching swatch selection logic)
  assign variant_to_link = product.selected_or_first_available_variant

  if settings.transition_to_main_product
    assign featured_image = variant_to_link.featured_image
    if featured_image == blank
      assign featured_image = product.featured_media.preview_image
    endif

    if featured_image != blank
      assign featured_media_url = featured_image | image_url: width: 500
    endif
  endif

  assign onboarding = false
  if product.id == empty or product == blank
    assign onboarding = true
  endif

  # Coffee Roast Style filter sync: when a Coffee Roast Style filter is active, the card
  # should reflect (and link to) the matching variant. Only opt in for products in the
  # Shopify "Coffee" taxonomy category — apparel/merch is left untouched.
  assign is_coffee_card = false
  if onboarding == false and product.category.name == 'Coffee'
    assign roast_option_index = null
    for opt in product.options_with_values
      assign opt_name = opt.name | downcase
      if opt_name contains 'roast' or opt_name contains 'grind'
        assign roast_option_index = forloop.index
        assign roast_option_name = opt.name
        break
      endif
    endfor

    if roast_option_index != null
      assign is_coffee_card = true
    endif
  endif
%}

<product-card
  class="product-card size-style product-card--{{ card_layout }}"
  style="{% render 'size-style', settings: block_settings %} --product-card-horizontal-image-width: {{ card_horizontal_image_width }}px;"
  data-product-id="{{ product.id }}"
  id="product-card-{{ block.id }}"
  {% if settings.transition_to_main_product %}
    data-product-transition="true"
    data-featured-media-url="{{ featured_media_url }}"
    on:click="/handleViewTransition"
  {% endif %}
  {% if is_coffee_card %}
    data-coffee-card="true"
    data-product-base-url="{{ product.url }}"
    data-roast-option-name="{{ roast_option_name | escape }}"
    data-roast-option-index="{{ roast_option_index }}"
  {% endif %}
  {{ block.shopify_attributes }}
  {% if onboarding %}
    data-placeholder="true"
  {% endif %}
>
  <a
    id="{{ product_card_id | md5 }}"
    {% unless onboarding %}
      href="{{ variant_to_link.url }}"
    {% endunless %}
    class="product-card__link"
    ref="productCardLink"
  >
    <span class="visually-hidden">
      {{ product.title }}
    </span>
  </a>
  <div
    class="
      product-card__content
      layout-panel-flex
      layout-panel-flex--column
      product-grid__card
      spacing-style
      border-style
      gap-style
      {% if block_settings.inherit_color_scheme == false %} color-{{ block_settings.color_scheme }}{% endif %}
    "
    style="
      {% render 'border-override', settings: block_settings %}
      {% render 'layout-panel-style', settings: block_settings %}
      {% render 'spacing-style', settings: block_settings %}
      {% render 'gap-style', value: product_card_gap_value, name: 'product-card-gap' %}
      {% if block_settings.use_mobile_gap %}
        {% render 'gap-style', value: block_settings.mobile_product_card_gap, name: 'product-card-gap-mobile' %}
      {% else %}
        {% render 'gap-style', value: product_card_gap_value, name: 'product-card-gap-mobile' %}
      {% endif %}
      --quick-add-display: {% if has_quick_add %}flex{% else %}none{% endif %};
      --quick-add-mobile-display: {% if has_mobile_quick_add %}flex{% else %}none{% endif %};
      --quick-add-mobile-opacity: {% if has_mobile_quick_add %}1{% else %}0{% endif %};
      {% if block_settings.padding-inline-start > 0 %}--zoom-out-padding-inline-start: min(var(--padding-xs), {{ block_settings.padding-inline-start | times: 0.7}}px);{% endif %}
      {% if block_settings.padding-inline-end > 0 %}--zoom-out-padding-inline-end: min(var(--padding-xs), {{ block_settings.padding-inline-end | times: 0.7}}px);{% endif %}
      {% if block_settings.padding-block-start > 0 %}--zoom-out-padding-block-start: min(var(--padding-xs), {{ block_settings.padding-block-start | times: 0.7}}px);{% endif %}
      {% if block_settings.padding-block-end > 0 %}--zoom-out-padding-block-end: min(var(--padding-xs), {{ block_settings.padding-block-end | times: 0.7}}px);{% endif %}
    "
  >
    {{ children }}
    {%- if is_coffee_card -%}
      {%- capture variants_json -%}
        [
          {%- for variant in product.variants -%}
            {%- liquid
              case roast_option_index
                when 1
                  assign roast_value = variant.option1
                when 2
                  assign roast_value = variant.option2
                when 3
                  assign roast_value = variant.option3
              endcase
              assign variant_image = variant.featured_image | default: variant.image | default: product.featured_media.preview_image
            -%}
            {
              "id": {{ variant.id | json }},
              "roast": {{ roast_value | default: '' | json }},
              "url": {{ variant.url | json }},
              "available": {{ variant.available | json }},
              "price": {{ variant.price | money | json }},
              "compare_at_price": {{ variant.compare_at_price | money | json }},
              "image_src": {{ variant_image | image_url: width: 800 | json }},
              "image_alt": {{ variant_image.alt | default: product.title | json }},
              "image_width": {{ variant_image.width | default: 800 | json }},
              "image_height": {{ variant_image.height | default: 800 | json }}
            }{%- unless forloop.last -%},{%- endunless -%}
          {%- endfor -%}
        ]
      {%- endcapture -%}
      <script type="application/json" data-coffee-variants>{{ variants_json | strip_newlines }}</script>
    {%- endif -%}
  </div>
</product-card>

{%- if is_coffee_card -%}
  <script src="{{ 'coffee-roast-swap.js' | asset_url }}" type="module" fetchpriority="low"></script>
{%- endif -%}

{% stylesheet %}
  .product-card__placeholder-image svg {
    height: 100%;
  }

  @media screen and (max-width: 749px) {
    .product-card slideshow-arrows .slideshow-control {
      display: none;
    }
  }

  /* When cards inside a resource list are horizontal, force the parent grid
     to a single column so cards stack vertically instead of fighting for
     space side-by-side. */
  .resource-list--grid:has(> .resource-list__item product-card.product-card--horizontal),
  .resource-list--grid:has(> product-card.product-card--horizontal) {
    grid-template-columns: 1fr;
  }

  @media screen and (min-width: 750px) {
    .resource-list--grid:has(> .resource-list__item product-card.product-card--horizontal),
    .resource-list--grid:has(> product-card.product-card--horizontal) {
      grid-template-columns: 1fr;
    }
  }

  /* Horizontal layout: gallery on the left (absolute), middle column flows
     as a flex stack so title + price hug each other naturally, quick-add on
     the right (absolute). Padding reserves space for the absolute siblings. */
  product-card.product-card--horizontal > .product-card__content {
    --horizontal-image-width: var(--product-card-horizontal-image-width, 96px);
    --horizontal-quick-add-width: 7rem;
    --horizontal-side-gap: var(--padding-md, 16px);

    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: stretch;
    position: relative;
    gap: var(--padding-2xs, 4px);
    padding-inline-start: calc(var(--horizontal-image-width) + var(--horizontal-side-gap));
    padding-inline-end: calc(var(--horizontal-quick-add-width) + var(--horizontal-side-gap));
    min-height: var(--horizontal-image-width);
  }

  product-card.product-card--horizontal > .product-card__content > * {
    min-width: 0;
  }

  /* Gallery: pinned to the left, vertically centered */
  product-card.product-card--horizontal .card-gallery {
    position: absolute;
    inset-inline-start: 0;
    inset-block-start: 50%;
    transform: translateY(-50%);
    width: var(--horizontal-image-width);
    margin: 0;
  }

  /* Quick-add: pinned to the right, vertically centered */
  product-card.product-card--horizontal .product-quick-add-block {
    position: absolute;
    inset-inline-end: 0;
    inset-block-start: 50%;
    transform: translateY(-50%);
    width: var(--horizontal-quick-add-width);
    padding-inline: 0;
    margin: 0;
  }

  product-card.product-card--horizontal .product-quick-add-block .quick-add__button {
    padding-inline: var(--padding-md, 16px);
    padding-block: 0;
    @media only screen and (max-width: 749px) {
      white-space: wrap;
    }
  }

  /* Disable overlay quick-add and roast badge in horizontal mode —
     there's a real ADD button, and the roast label clutters the small thumb. */
  product-card.product-card--horizontal .card-gallery .quick-add,
  product-card.product-card--horizontal .product-badges__badge--roast {
    display: none;
  }
{% endstylesheet %}
