{%- doc -%}
  Renders the cart drawer footer (subtotal + checkout button).
{%- enddoc -%}

{%- liquid
  assign show_compare = false
  if cart.original_total_price > cart.total_price
    assign show_compare = true
  endif

  # Calculate subscription savings: Shopify bakes selling plan discounts into
  # both original_total_price and total_price, so they match. Sum up the
  # difference between variant.price and final_price for subscription items.
  assign subscription_total_savings = 0
  for item in cart.items
    if item.selling_plan_allocation
      assign full_item_line_price = item.variant.price | times: item.quantity
      assign item_sub_savings = full_item_line_price | minus: item.final_line_price
      if item_sub_savings > 0
        assign subscription_total_savings = subscription_total_savings | plus: item_sub_savings
      endif
    endif
  endfor
  assign show_subscription_compare = false
  if subscription_total_savings > 0 and show_compare == false
    assign show_subscription_compare = true
    assign cart_total_before_sub = cart.total_price | plus: subscription_total_savings
  endif

  if settings.currency_code_enabled_cart_total
    assign total_price_display = cart.total_price | money_with_currency
    assign original_price_display = cart.original_total_price | money_with_currency
    if show_subscription_compare
      assign sub_original_price_display = cart_total_before_sub | money_with_currency
    endif
  else
    assign total_price_display = cart.total_price | money
    assign original_price_display = cart.original_total_price | money
    if show_subscription_compare
      assign sub_original_price_display = cart_total_before_sub | money
    endif
  endif
-%}

<div class="cart-drawer-summary">
  <div class="cart-drawer-summary__row">
    <span class="cart-drawer-summary__label">Subtotal:</span>
    <span class="cart-drawer-summary__values">
      {%- if show_compare -%}
        <s class="cart-drawer-summary__original">{{ original_price_display }}</s>
      {%- elsif show_subscription_compare -%}
        <s class="cart-drawer-summary__original">{{ sub_original_price_display }}</s>
      {%- endif -%}
      <text-component
        ref="cartTotal"
        value="{{ total_price_display | strip_html }}"
        class="cart-drawer-summary__total"
        data-testid="cart-total-value"
        data-cart-subtotal
      >
        {{ total_price_display }}
      </text-component>
    </span>
  </div>

  <div class="cart-drawer-summary__actions">
    <button
      type="submit"
      id="checkout"
      name="checkout"
      class="cart-drawer-summary__checkout"
      form="cart-form"
      {% if cart == empty %}disabled{% endif %}
    >
      {{ 'content.checkout' | t | default: 'Checkout' }}
    </button>

    <p class="cart-drawer-summary__note">
      *Shipping &amp; taxes calculated at checkout
    </p>
  </div>
</div>

{% stylesheet %}
  .cart-drawer-summary {
    background-color: #fcfbf6;
    box-shadow: 4px 0 2.5px rgba(0, 0, 0, 0.1);
    padding: 16px 15px 24px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    width: 100%;
    border-bottom-right-radius: 8px;
  }

  .cart-drawer-summary__row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
  }

  .cart-drawer-summary__label {
    font-family: 'Inter', sans-serif;
    font-weight: 700;
    font-size: 18px;
    line-height: 1;
    color: #1b1b1b;
  }

  .cart-drawer-summary__values {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: 'Inter', sans-serif;
    font-size: 16px;
    line-height: 1;
  }

  .cart-drawer-summary__original {
    color: #3d3a35;
    text-decoration: line-through;
    font-weight: 400;
  }

  .cart-drawer-summary__total {
    color: #1b1b1b;
    font-weight: 700;
  }

  .cart-drawer-summary__actions {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    width: 100%;
  }

  .cart-drawer-summary__checkout {
    background-color: #3d3a35;
    color: #f2edd7;
    font-family: 'Inter', sans-serif;
    font-weight: 700;
    font-size: 16px;
    text-transform: uppercase;
    line-height: 1;
    border: none;
    padding: 16px 24px;
    width: 100%;
    cursor: pointer;
    transition: opacity 0.2s ease;
  }

  .cart-drawer-summary__checkout:hover:not(:disabled) {
    opacity: 0.9;
  }

  .cart-drawer-summary__checkout:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .cart-drawer-summary__note {
    font-family: 'Inter', sans-serif;
    font-weight: 400;
    font-size: 14px;
    line-height: 1.1;
    color: #3d3a35;
    margin: 0;
    text-align: center;
  }
{% endstylesheet %}
