{%- liquid
  assign block_settings = block.settings
  assign product_resource = closest.product
  assign variant = product_resource.selected_or_first_available_variant

  assign roast_value = 0
  assign metafield_path = block_settings.metafield | strip
  if metafield_path != blank
    assign metafield_parts = metafield_path | split: '.'
    assign metafield_namespace = metafield_parts[0]
    assign metafield_key = metafield_parts[1]
    if metafield_namespace != blank and metafield_key != blank
      if block_settings.metafield_source == 'variant'
        assign raw_value = variant.metafields[metafield_namespace][metafield_key]
      else
        assign raw_value = product_resource.metafields[metafield_namespace][metafield_key]
      endif
      assign roast_value = raw_value | times: 1
    endif
  endif

  assign max_steps = block_settings.max_steps | default: 5
  if roast_value > max_steps
    assign roast_value = max_steps
  endif
  if roast_value < 0
    assign roast_value = 0
  endif

  assign hide_when_empty = block_settings.hide_when_empty
-%}

{%- if hide_when_empty == false or roast_value > 0 -%}
  <roast-profile
    class="
      roast-profile spacing-style
      {% if block_settings.type_preset != '' %} {{ block_settings.type_preset }}{% endif %}
    "
    style="
      {% render 'spacing-style', settings: block_settings %}
      --roast-circle-size: {{ block_settings.circle_size }}px;
      --roast-circle-gap: {{ block_settings.circle_gap }}px;
    "
    data-block-id="{{ block.id }}"
    data-product-id="{{ product_resource.id }}"
    {{ block.shopify_attributes }}
  >
    {%- if block_settings.heading != blank -%}
      <div class="roast-profile__heading">{{ block_settings.heading | escape }}</div>
    {%- endif -%}

    <div class="roast-profile__scale">
      <span class="roast-profile__end-label">{{ block_settings.start_label | escape }}</span>
      <span class="roast-profile__circles" role="img" aria-label="{{ block_settings.heading | escape }}: {{ roast_value }} of {{ max_steps }}">
        {%- for i in (1..max_steps) -%}
          {%- if i <= roast_value -%}
            <span class="roast-profile__circle roast-profile__circle--filled" aria-hidden="true"></span>
          {%- else -%}
            <span class="roast-profile__circle" aria-hidden="true"></span>
          {%- endif -%}
        {%- endfor -%}
      </span>
      <span class="roast-profile__end-label">{{ block_settings.end_label | escape }}</span>
    </div>
  </roast-profile>
{%- endif -%}

{% stylesheet %}
  .roast-profile {
    display: flex;
    flex-direction: column;
    gap: var(--padding-xs, 8px);
    width: 100%;
  }

  .roast-profile__heading {
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .roast-profile__scale {
    display: flex;
    align-items: center;
    gap: 1rem;
    font-size: var(--font-size--sm, 0.875rem);
  }

  .roast-profile__end-label {
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .roast-profile__circles {
    display: inline-flex;
    align-items: center;
    gap: var(--roast-circle-gap, 8px);
  }

  .roast-profile__circle {
    color: #525236;
    width: var(--roast-circle-size, 12px);
    height: var(--roast-circle-size, 12px);
    border-radius: 50%;
    border: 1.5px solid currentColor;
    box-sizing: border-box;
    display: inline-block;
    flex: 0 0 auto;
  }

  .roast-profile__circle--filled {
    background-color: currentColor;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Roast profile",
  "tag": null,
  "settings": [
    {
      "type": "paragraph",
      "content": "Reads a roast level (1-5) from a product or variant metafield and renders it as a filled-circle scale."
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Roast profile"
    },
    {
      "type": "text",
      "id": "start_label",
      "label": "Start label",
      "default": "Light"
    },
    {
      "type": "text",
      "id": "end_label",
      "label": "End label",
      "default": "Dark"
    },
    {
      "type": "header",
      "content": "Metafield"
    },
    {
      "type": "select",
      "id": "metafield_source",
      "label": "Source",
      "options": [
        { "value": "product", "label": "Product metafield" },
        { "value": "variant", "label": "Variant metafield" }
      ],
      "default": "product"
    },
    {
      "type": "text",
      "id": "metafield",
      "label": "Metafield (namespace.key)",
      "default": "custom.roast_profile",
      "info": "Format: namespace.key — must be a number between 1 and the max steps below."
    },
    {
      "type": "checkbox",
      "id": "hide_when_empty",
      "label": "Hide block when metafield is empty",
      "default": true
    },
    {
      "type": "header",
      "content": "Scale"
    },
    {
      "type": "range",
      "id": "max_steps",
      "label": "Number of steps",
      "min": 3,
      "max": 10,
      "step": 1,
      "default": 5
    },
    {
      "type": "range",
      "id": "circle_size",
      "label": "Circle size",
      "min": 6,
      "max": 32,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "circle_gap",
      "label": "Gap between circles",
      "min": 2,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 8
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "type_preset",
      "label": "t:settings.heading_preset",
      "options": [
        { "value": "", "label": "t:options.default" },
        { "value": "paragraph", "label": "t:options.paragraph" },
        { "value": "h6", "label": "t:options.h6" },
        { "value": "h7", "label": "t:options.h7" }
      ],
      "default": ""
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-inline-start",
      "label": "t:settings.left",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-inline-end",
      "label": "t:settings.right",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Roast profile",
      "category": "t:categories.product"
    }
  ]
}
{% endschema %}
