<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div
  class="section section--{{ section.settings.section_width }} color-{{ section.settings.color_scheme }} spacing-style legal-page"
  style="{% render 'spacing-style', settings: section.settings %}"
  data-testid="main-page-legal"
>
  <header class="legal-page__header">
    <h1 class="legal-page__title h4">{{ page.title }}</h1>
  </header>

  <div class="legal-page__body rte">
    {{ page.content }}
  </div>
</div>

{% stylesheet %}
  .legal-page {
    --page-content-width: var(--narrow-page-width);
    --page-width: calc(var(--page-content-width) + (var(--page-margin) * 2));
  }

  .legal-page__header {
    text-align: center;
    margin-block-end: var(--gap-2xl, 48px);
  }

  .legal-page__title {
    margin: 0;
    text-transform: uppercase;
  }

  .legal-page__body :is(h1, h2, h3, h4, h5, h6) {
    font-family: var(--font-h6--family);
    font-size: var(--font-h6--size);
    line-height: var(--font-h6--line-height);
    color: var(--font-h6--color, var(--color-foreground-heading));
    text-transform: uppercase;
    margin-block: var(--gap-xl, 32px) var(--gap-sm, 12px);
  }

  .legal-page__body :is(h1, h2, h3, h4, h5, h6):first-child {
    margin-block-start: 0;
  }

  .legal-page__body a {
    color: var(--Primary-Orange, #C7893A);
    text-decoration: underline;
    text-underline-offset: 0.2em;
  }

  .legal-page__body a:hover,
  .legal-page__body a:focus-visible {
    text-decoration-thickness: 2px;
  }

  .legal-page__body p {
    margin-block: 0 var(--gap-md, 16px);
  }

  .legal-page__body ul,
  .legal-page__body ol {
    margin-block: 0 var(--gap-md, 16px);
    padding-inline-start: 1.5rem;
  }

  .legal-page__body li {
    margin-block: 0.25rem;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Legal page content",
  "settings": [
    {
      "type": "select",
      "id": "section_width",
      "label": "t:settings.width",
      "options": [
        { "value": "page-width", "label": "t:options.page" },
        { "value": "full-width", "label": "t:options.full" }
      ],
      "default": "page-width"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 64
    }
  ],
  "presets": [
    {
      "name": "Legal page content"
    }
  ]
}
{% endschema %}
